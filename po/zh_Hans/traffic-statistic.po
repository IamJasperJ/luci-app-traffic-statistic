msgid "Traffic is counted in the kernel and written in batches. Receive and transmit are shown from the client device perspective."
msgstr "流量由内核计数并分批写入；接收和发送方向均以客户端设备为视角。"

msgid "Receive and transmit are from the client device perspective. Counters are split by IPv4 and IPv6."
msgstr "接收和发送方向以客户端设备为视角，并分别统计 IPv4 与 IPv6。"

msgid "Use an external disk path for long retention periods. /tmp is volatile and avoids flash writes."
msgstr "长期保留建议使用外置存储路径；/tmp 为易失存储，可避免写入闪存。"

msgid "Use an absolute path without spaces or parent-directory components."
msgstr "请使用不含空格或上级目录片段的绝对路径。"

msgid "Use a valid Linux interface name."
msgstr "请输入有效的 Linux 接口名称。"

msgid "Usually leave empty. Bridge member ports are discovered automatically."
msgstr "通常留空即可，桥接成员端口会被自动发现。"

msgid "Seconds. Longer intervals reduce flash writes."
msgstr "单位为秒；更长的间隔可减少闪存写入。"

msgid "Days of history retained for this group."
msgstr "此配置组保留历史数据的天数。"

msgid "LAN"
msgstr "局域网"

msgid "Loading…"
msgstr "正在加载…"

msgid "Reading statistics…"
msgstr "正在读取统计数据…"

msgid "Choose a valid custom time range."
msgstr "请选择有效的自定义时间范围。"

msgid "All saved history for the selected interface group will be deleted. Live counters are not interrupted."
msgstr "将删除所选接口配置组的全部历史数据，实时计数不会中断。"

msgid "offload-safe bridge accounting"
msgstr "兼容流量卸载的桥接统计"

msgid "basic interface accounting"
msgstr "基础接口统计"

msgid "%s · %s · every %s seconds · keep %s days"
msgstr "%s · %s · 每 %s 秒写入 · 保留 %s 天"

msgid "%s data points"
msgstr "%s 个数据点"
